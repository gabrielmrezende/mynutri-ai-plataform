# ==================================
# MyNutri AI — Variáveis de Ambiente (TEMPLATE)
# ==================================
# INSTRUÇÕES:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha com seus valores reais
# 3. NUNCA commite o arquivo .env no Git (já está no .gitignore)
# 4. Use secrets manager em produção (AWS Secrets Manager, Azure Key Vault, etc)

# ───────────────────────────────────────────────────────────────
# Django
# ───────────────────────────────────────────────────────────────
# Gere uma nova SECRET_KEY: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-random-secret-key-here-min-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ───────────────────────────────────────────────────────────────
# Banco de Dados
# ───────────────────────────────────────────────────────────────
# Desenvolvimento: sqlite3
# Produção: PostgreSQL
DATABASE_URL=sqlite:///db.sqlite3

# ───────────────────────────────────────────────────────────────
# API de Inteligência Artificial (OpenAI)
# ───────────────────────────────────────────────────────────────
# Gere uma chave em: https://platform.openai.com/api-keys
# ⚠️ SEGURANÇA: Use uma chave dedicada para este projeto
# ⚠️ SEGURANÇA: Defina limites de uso/quota na dashboard OpenAI
AI_API_KEY=sk-proj-your-api-key-here
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo

# ───────────────────────────────────────────────────────────────
# Logging (opcional)
# ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
